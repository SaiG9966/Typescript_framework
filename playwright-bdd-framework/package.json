{
  "name": "playwright-bdd-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "identity": "node -e \"const n=Buffer.from('VGhpcnVtYW5kYXMgU2FpdGVqYSBHb3Vk','base64').toString('utf8');console.log('\\n[Framework Owner] '+n)\"",
    "pretest": "npm run identity",
    "pretest:one": "npm run identity",
    "presteps:generate": "npm run identity",
    "prereport": "npm run identity",
    "preopen-report": "npm run identity",
    "pretest:report": "npm run identity",
    "pretest:report:no-open": "npm run identity",
    "test:raw": "cucumber-js --config src/config/cucumber.cjs",
    "test": "npm run test:raw",
    "test:one": "node src/utils/runSingleTest.js",
    "test:smoke": "cross-env TAGS=@smoke npm run test:raw",
    "test:regression": "cross-env TAGS=@regression npm run test:raw",
    "test:wip": "cross-env TAGS=@wip npm run test:raw",
    "test:flaky": "cross-env TAGS=@flaky RETRY=3 npm run test:raw",
    "test:api": "cross-env TAGS=@api npm run test:raw",
    "steps:generate": "node src/utils/generateStepDefs.js",
    "steps:check": "node src/utils/checkSteps.js",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run print-report",
    "open-report": "npm run report:open",
    "print-report": "node src/utils/showReportPath.js",
    "test:report": "node src/utils/runReportWorkflow.js --open",
    "test:report:no-open": "node src/utils/runReportWorkflow.js",
    "test:retry-report": "node src/utils/retryReport.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.js\"",
    "bdd": "cucumber-js --config src/config/cucumber.cjs",
    "test": "npm run bdd"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "allure-commandline": "^2.37.0",
    "allure-cucumberjs": "^3.6.0",
    "allure-js-commons": "^3.6.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cucumber": "^2.0.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
